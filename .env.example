# Copy to .env and adjust if needed:
#   cp .env.example .env
#
# Docker Compose loads .env automatically for ${VAR} substitution in compose files.

# --- Postgres (db service + web DATABASE_URL) ---
POSTGRES_USER=lander
POSTGRES_PASSWORD=lander
POSTGRES_DB=lander

# --- MySQL ---
MYSQL_ROOT_PASSWORD=lander
MYSQL_DATABASE=lander
MYSQL_USER=lander
MYSQL_PASSWORD=lander

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Web app ---
PORT=3000
MONGODB_URI=mongodb://mongo:27017/demo_lander
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=demo_lander
MYSQL_HOST=mysql
MYSQL_PORT=3306
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=demo-uploads
S3_REGION=us-east-1
ENV_CUSTOM="Hello World"
